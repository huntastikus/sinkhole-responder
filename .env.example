# Copy this file to .env and change only the settings you need. Every setting is
# optional; defaults match docker-compose.yml. Do not put passwords in .env.

# Image/build and process identity.
SINKHOLE_IMAGE=huntastikus/sinkhole-responder:latest
SINKHOLE_BUILD_VERSION=docker
SINKHOLE_UID=65532
SINKHOLE_GID=65532
SINKHOLE_RESTART_POLICY=unless-stopped

# Host directories. Create them before starting Compose.
SINKHOLE_DATA_DIR=./data
SINKHOLE_CERTS_DIR=./certs
SINKHOLE_SECRETS_DIR=./secrets

# Host bind addresses.
SINKHOLE_DATA_BIND_ADDRESS=0.0.0.0
SINKHOLE_ADMIN_BIND_ADDRESS=0.0.0.0
SINKHOLE_MANAGEMENT_BIND_ADDRESS=127.0.0.1

# Listener ports. Each value is used inside the container and on the host so
# redirects always advertise the reachable port.
SINKHOLE_HTTP_PORT=80
SINKHOLE_HTTPS_PORT=443
SINKHOLE_ADMIN_HTTP_PORT=8080
SINKHOLE_ADMIN_HTTPS_PORT=8443
SINKHOLE_MANAGEMENT_PORT=9090

# Common optional runtime overrides. Remove the leading # to enable one.
# SINKHOLE_ADMIN_ENABLED=true
# SINKHOLE_ADMIN_TLS_ENABLED=true
# SINKHOLE_MANAGEMENT_ENABLED=true
# SINKHOLE_ADMIN_PASSWORD_FILE=/run/secrets/admin_password
# SINKHOLE_TLS_MODE=local-ca
# SINKHOLE_CA_CERT_FILE=/certs/ca.crt
# SINKHOLE_CA_KEY_FILE=/certs/ca.key
# SINKHOLE_ADMIN_TLS_CERT_FILE=/certs/admin.crt
# SINKHOLE_ADMIN_TLS_KEY_FILE=/certs/admin.key
# SINKHOLE_TLS_CERT_FILE=/certs/responder.crt
# SINKHOLE_TLS_KEY_FILE=/certs/responder.key
# SINKHOLE_TLS_HOSTS=blocked.example,ads.example
# SINKHOLE_RULEPACKS=recommended
# SINKHOLE_LOG_POST_BODY=false
# SINKHOLE_POST_BODY_LOG_MAX_BYTES=4096

# All less-common runtime overrides, their types, defaults, and pair requirements
# are documented in README.md under "Container parameters" and
# "Configuration reference".
